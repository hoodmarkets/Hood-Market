{
  "name": "hoodmarkets-api",
  "version": "1.0.0",
  "description": "hood.markets launcher API — Robinhood Chain, Privy web deploys",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:api",
    "build:api": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc -p tsconfig.json && mkdir -p dist/liquid dist/lib/artifacts && cp src/liquid/liquidFactoryAbi.json dist/liquid/ && cp src/lib/artifacts/HoodMarketsV3Token.json dist/lib/artifacts/",
    "build:backend": "npm run build:api",
    "start": "node dist/index.js",
    "dev:backend": "tsx src/index.ts",
    "purge-deprecated-v3": "tsx scripts/purge-deprecated-v3-catalog.ts",
    "purge-deprecated-v3:dry-run": "tsx scripts/purge-deprecated-v3-catalog.ts --dry-run",
    "purge-catalog": "tsx scripts/purge-catalog.ts",
    "purge-catalog:dry-run": "tsx scripts/purge-catalog.ts --dry-run",
    "delete-catalog-token": "tsx scripts/delete-catalog-token.ts",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.72",
    "@langchain/openai": "^0.3.17",
    "@lighthouse-web3/sdk": "^0.4.5",
    "@neynar/nodejs-sdk": "^1.71.0",
    "@privy-io/node": "^0.13.0",
    "@supabase/supabase-js": "^2.103.0",
    "clanker-sdk": "^4.2.16",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^6.2.2",
    "liquid-sdk": "^1.7.2",
    "node-telegram-bot-api": "^0.66.0",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "tsx": "^4.19.3",
    "viem": "^2.23.10",
    "winston": "^3.17.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.24",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/sqlite3": "^3.1.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
